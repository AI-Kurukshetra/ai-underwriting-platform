generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

model Organization {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  createdAt             DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  applications          Application[]
  dataSourceConnections DataSourceConnection[]
  ingestionRuns         IngestionRun[]
  modelVersions         ModelVersion[]
  portfolioMetrics      PortfolioMetric[]
  profiles              Profile[]
  workflows             Workflow[]

  @@map("organizations")
  @@schema("public")
}

model Profile {
  id             String       @id @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  fullName       String       @map("full_name")
  role           String       @default("underwriter")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  users          users        @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("profiles")
  @@schema("public")
}

model Workflow {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  config         Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("workflows")
  @@schema("public")
}

model ModelVersion {
  id                String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String?           @map("organization_id") @db.Uuid
  name              String
  version           String
  status            String
  auc               Decimal           @db.Decimal(4, 3)
  precision         Decimal           @db.Decimal(4, 3)
  recall            Decimal           @db.Decimal(4, 3)
  drift             Decimal           @default(0) @db.Decimal(5, 2)
  notes             String            @default("")
  deployedAt        DateTime          @map("deployed_at") @db.Date
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  trafficShare      Decimal           @default(0) @map("traffic_share") @db.Decimal(5, 2)
  approvalThreshold Decimal           @default(35) @map("approval_threshold") @db.Decimal(5, 2)
  modelEvaluations  ModelEvaluation[]
  organization      Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("model_versions")
  @@schema("public")
}

model Application {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String?                 @map("organization_id") @db.Uuid
  externalRef            String                  @unique @map("external_ref")
  customerName           String                  @map("customer_name")
  email                  String
  productLine            String                  @map("product_line")
  amountRequested        Decimal                 @map("amount_requested") @db.Decimal(12, 2)
  annualIncome           Decimal                 @map("annual_income") @db.Decimal(12, 2)
  creditScore            Int                     @map("credit_score")
  debtToIncome           Decimal                 @map("debt_to_income") @db.Decimal(5, 4)
  claimsCount            Int                     @default(0) @map("claims_count")
  fraudSignals           String[]                @default([]) @map("fraud_signals")
  documentConfidence     Decimal                 @default(0.8) @map("document_confidence") @db.Decimal(5, 4)
  geospatialRisk         Decimal                 @default(0.3) @map("geospatial_risk") @db.Decimal(5, 4)
  state                  String
  status                 String                  @default("new")
  workflowStage          String                  @default("intake") @map("workflow_stage")
  submittedAt            DateTime                @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt              DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  applicationDataSources ApplicationDataSource[]
  applicationDocuments   ApplicationDocument[]
  organization           Organization?           @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  auditLogs              AuditLog[]
  decisions              Decision[]
  fraudAlerts            FraudAlert[]
  fraudCases             FraudCase[]
  ingestionRuns          IngestionRun[]
  modelEvaluations       ModelEvaluation[]
  riskScore              RiskScore?

  @@map("applications")
  @@schema("public")
}

model RiskScore {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId      String      @unique @map("application_id") @db.Uuid
  score              Decimal     @db.Decimal(5, 2)
  band               String
  fraudProbability   Decimal     @map("fraud_probability") @db.Decimal(5, 2)
  documentConfidence Decimal     @map("document_confidence") @db.Decimal(5, 4)
  recommendation     String
  reasons            String[]    @default([])
  factors            Json        @default("[]")
  modelVersion       String      @map("model_version")
  generatedAt        DateTime    @default(now()) @map("generated_at") @db.Timestamptz(6)
  application        Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("risk_scores")
  @@schema("public")
}

model Decision {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  decision      String
  actor         String
  notes         String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("decisions")
  @@schema("public")
}

model AuditLog {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  actor         String
  action        String
  details       String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("audit_logs")
  @@schema("public")
}

model FraudAlert {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  customerName  String      @map("customer_name")
  severity      String
  reason        String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("fraud_alerts")
  @@schema("public")
}

model PortfolioMetric {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  label          String
  value          String
  delta          String
  tone           String
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("portfolio_metrics")
  @@schema("public")
}

model ApplicationDocument {
  id                  String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId       String      @map("application_id") @db.Uuid
  fileName            String      @map("file_name")
  mimeType            String      @map("mime_type")
  sizeBytes           BigInt      @map("size_bytes")
  extractedConfidence Decimal     @default(0.8) @map("extracted_confidence") @db.Decimal(5, 4)
  analysisSummary     String      @default("") @map("analysis_summary")
  storagePath         String?     @map("storage_path")
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  documentType        String      @default("other") @map("document_type")
  verificationStatus  String      @default("review") @map("verification_status")
  extractedData       Json        @default("{}") @map("extracted_data")
  application         Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([applicationId, createdAt(sort: Desc)], map: "application_documents_application_id_idx")
  @@map("application_documents")
  @@schema("public")
}

model ApplicationDataSource {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId  String      @map("application_id") @db.Uuid
  sourceType     String      @map("source_type")
  status         String
  confidence     Decimal     @default(0) @db.Decimal(5, 4)
  freshnessHours Int         @default(0) @map("freshness_hours")
  detail         String      @default("")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([applicationId, createdAt(sort: Desc)], map: "application_data_sources_application_id_idx")
  @@map("application_data_sources")
  @@schema("public")
}

model DataSourceConnection {
  id                    String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId        String?       @map("organization_id") @db.Uuid
  sourceType            String        @map("source_type")
  providerName          String        @map("provider_name")
  status                String
  syncMode              String        @map("sync_mode")
  defaultFreshnessHours Int           @default(24) @map("default_freshness_hours")
  coverage              Decimal       @default(0) @db.Decimal(5, 2)
  notes                 String        @default("")
  lastSyncAt            DateTime?     @map("last_sync_at") @db.Timestamptz(6)
  createdAt             DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  organization          Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organizationId, sourceType, createdAt(sort: Desc)], map: "data_source_connections_organization_id_idx")
  @@map("data_source_connections")
  @@schema("public")
}

model IngestionRun {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String?       @map("organization_id") @db.Uuid
  applicationId    String?       @map("application_id") @db.Uuid
  sourceType       String        @map("source_type")
  providerName     String        @map("provider_name")
  status           String
  recordsProcessed Int           @default(0) @map("records_processed")
  triggeredBy      String        @map("triggered_by")
  detail           String
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  application      Application?  @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([applicationId, createdAt(sort: Desc)], map: "ingestion_runs_application_id_idx")
  @@index([organizationId, createdAt(sort: Desc)], map: "ingestion_runs_organization_id_idx")
  @@map("ingestion_runs")
  @@schema("public")
}

model FraudCase {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String      @map("application_id") @db.Uuid
  category      String
  score         Decimal     @db.Decimal(5, 2)
  status        String
  explanation   String
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([applicationId, createdAt(sort: Desc)], map: "fraud_cases_application_id_idx")
  @@map("fraud_cases")
  @@schema("public")
}

model ModelEvaluation {
  id                String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId     String       @map("application_id") @db.Uuid
  modelVersionId    String       @map("model_version_id") @db.Uuid
  modelName         String       @map("model_name")
  version           String
  lane              String
  score             Decimal      @db.Decimal(5, 2)
  recommendation    String
  deltaFromChampion Decimal      @default(0) @map("delta_from_champion") @db.Decimal(5, 2)
  verdict           String
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  application       Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  modelVersion      ModelVersion @relation(fields: [modelVersionId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([applicationId, createdAt(sort: Desc)], map: "model_evaluations_application_id_idx")
  @@index([modelVersionId, createdAt(sort: Desc)], map: "model_evaluations_model_version_id_idx")
  @@map("model_evaluations")
  @@schema("public")
}

